NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret
NEXT_PUBLIC_PUMPKIN_API_BASE_URL=https://test-app.pumpkin.date

NEXT_PUBLIC_DEFAULT_GAS_SPONSOR_CHAIN_KEY=bsc-testnet

# Optional global fallback when a chain-specific sponsor key is not configured.
SPONSOR_PRIVATE_KEY=0xYOUR_SPONSOR_PRIVATE_KEY

# Recommended per-chain sponsor keys used by the backend API route.
SPONSOR_PRIVATE_KEY__BSC_TESTNET=0xYOUR_BSC_TESTNET_SPONSOR_PRIVATE_KEY
SPONSOR_PRIVATE_KEY__SEPOLIA_TESTNET=0xYOUR_SEPOLIA_TESTNET_SPONSOR_PRIVATE_KEY
SPONSOR_PRIVATE_KEY__ARBITRUM_TESTNET=0xYOUR_ARBITRUM_TESTNET_SPONSOR_PRIVATE_KEY

# Legacy single-chain fallback variables are still supported, but the
# preferred multi-chain flow is:
# 1. edit config/gas-sponsor-chains.json
# 2. copy contracts/.env.example -> contracts/.env.<chain-key>
# 3. run pnpm sync:chains or one of the deploy scripts
